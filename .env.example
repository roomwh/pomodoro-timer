# Supabase 연결 자격 증명 (값은 .env.local에 채운다 — 이 파일은 키 이름만 문서화)
# Supabase 대시보드 또는 MCP get_project_url / get_publishable_keys로 조회.

# Supabase Project URL (예: https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# 공개(publishable/anon) API 키 — RLS로 보호되므로 클라이언트 노출 가능.
# modern publishable 키(sb_publishable_...) 권장. service_role 키는 절대 넣지 않는다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
